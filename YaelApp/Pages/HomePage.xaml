<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.HomePage"
             Title="Accueil">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24">
            <Label
                Text="Bienvenue sur l'application de Vianney et Yael !"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="28 "
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Label
                Text="Voici l'actualité sportive du jour :"
                FontSize="16"
                TextColor="Gray"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Image
                    Grid.Column="0"
                    Source="nadal_article.jpg"
                    HeightRequest="300"
                    Aspect="AspectFill"
                    SemanticProperties.Description="Nadal Retraite" />

                <Image
                    Grid.Column="1"
                    Source="wemby_article.jpg"
                    HeightRequest="300"
                    Aspect="AspectFill"
                    SemanticProperties.Description="Wenby Draft" />
            </Grid>

            <Button
                x:Name="GifDuJourButton"
                Text="Gif du jour"
                HorizontalOptions="Center"
                Margin="0,16,0,0"
                Padding="24,10" />
            
            <CarouselView x:Name="NewsCarousel"
                          HeightRequest="300"
                          Loop="True"
                          Margin="0,12,0,0">
                <CarouselView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>carousel1.jpeg</x:String>
                        <x:String>carousel2.jpg</x:String>
                        <x:String>carousel3.jpg</x:String>
                        <x:String>carousel4.jpg</x:String>
                        <x:String>carousel5.jpg</x:String>
                        <x:String>carousel6.jpg</x:String>
                        <x:String>carousel7.jpg</x:String>
                        <x:String>carousel8.jpg</x:String>
                    </x:Array>
                </CarouselView.ItemsSource>
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding .}"
                               Aspect="AspectFill"
                               HeightRequest="300" />
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <HorizontalStackLayout Spacing="16"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0">
                <Button Text="&lt;"
                        WidthRequest="56"
                        FontSize="22"
                        Clicked="OnPreviousClicked" />
                <Button Text="&gt;"
                        WidthRequest="56"
                        FontSize="22"
                        Clicked="OnNextClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
