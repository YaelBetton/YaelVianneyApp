<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.HomePage"
             Title="Accueil"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- En-tête -->
            <VerticalStackLayout Spacing="6" Padding="24,52,24,20" HorizontalOptions="Center">
                <Label Text="🏆"
                       FontSize="36"
                       HorizontalOptions="Center" />
                <Label Text="Sports App"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="de Vianney &amp; Yael"
                       FontSize="14"
                       TextColor="{StaticResource Gray500}"
                       HorizontalOptions="Center" />
                <BoxView HeightRequest="3"
                         WidthRequest="48"
                         CornerRadius="2"
                         Color="{StaticResource Primary}"
                         HorizontalOptions="Center"
                         Margin="0,6,0,0" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="24" Padding="20,24">

                <!-- Bouton Gif du jour -->
                <Button x:Name="GifDuJourButton"
                        Text="Gif du jour"
                        HorizontalOptions="Center"
                        Padding="32,12"
                        CornerRadius="20"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Primary}"
                        FontAttributes="Bold"
                        FontSize="15" />

                <!-- Section actualités -->
                <Label Text="Actualités du jour"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            HeightRequest="200"
                            >
                        <Image Source="nadal_article.jpg"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Nadal Retraite" />
                    </Border>
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            HeightRequest="200"
                            >
                        <Image Source="wemby_article.jpg"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Wemby Draft" />
                    </Border>
                </Grid>

                <!-- Section carrousel -->
                <Label Text="La semaine sportive"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        HeightRequest="260">
                    <CarouselView x:Name="NewsCarousel"
                                  HeightRequest="260"
                                  Loop="True">
                        <CarouselView.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>carousel1.jpeg</x:String>
                                <x:String>carousel2.jpg</x:String>
                                <x:String>carousel3.jpg</x:String>
                                <x:String>carousel4.jpg</x:String>
                                <x:String>carousel5.jpg</x:String>
                                <x:String>carousel6.jpg</x:String>
                                <x:String>carousel7.jpg</x:String>
                                <x:String>carousel8.jpg</x:String>
                            </x:Array>
                        </CarouselView.ItemsSource>
                        <CarouselView.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill"
                                       HeightRequest="260" />
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                </Border>

                <!-- Navigation carrousel -->
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Button Text="‹"
                            WidthRequest="48"
                            HeightRequest="48"
                            FontSize="22"
                            CornerRadius="24"
                            Padding="0"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource Gray600}"
                            Clicked="OnPreviousClicked" />
                    <Button Text="›"
                            WidthRequest="48"
                            HeightRequest="48"
                            FontSize="22"
                            CornerRadius="24"
                            Padding="0"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource Gray600}"
                            Clicked="OnNextClicked" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
