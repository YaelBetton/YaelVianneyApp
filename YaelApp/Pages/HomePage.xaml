<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.HomePage"
             Title="Accueil">
    <VerticalStackLayout
        Spacing="25"
        Padding="30,0"
        VerticalOptions="Center">

        <Image
            Source="dotnet_bot.png"
            SemanticProperties.Description="Bot .NET"
            HeightRequest="200"
            HorizontalOptions="Center" />

        <Label
            Text="Bienvenue sur la page d'accueil"
            SemanticProperties.HeadingLevel="Level1"
            FontSize="32"
            HorizontalOptions="Center" />

        <Label
            Text="Ceci est l'onglet Accueil"
            SemanticProperties.Description="Message de bienvenue"
            FontSize="18"
            HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>

