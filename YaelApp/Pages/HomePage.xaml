<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.HomePage"
             Title="Accueil">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24">
            <Label
                Text="Bienvenue sur l'application de Vianney et Yael !"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="28 "
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Label
                Text="Voici l'actualité sportive du jour :"
                FontSize="16"
                TextColor="Gray"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Image
                    Grid.Column="0"
                    Source="nadal_article.jpg"
                    HeightRequest="300"
                    Aspect="AspectFill"
                    SemanticProperties.Description="Nadal Retraite" />

                <Image
                    Grid.Column="1"
                    Source="wemby_article.jpg"
                    HeightRequest="300"
                    Aspect="AspectFill"
                    SemanticProperties.Description="Wenby Draft" />
            </Grid>

            <Button
                x:Name="GifDuJourButton"
                Text="Gif du jour"
                HorizontalOptions="Center"
                Margin="0,16,0,0"
                Padding="24,10" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
