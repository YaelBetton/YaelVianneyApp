<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YaelApp.ViewModels"
             x:Class="YaelApp.Pages.ScoreDetailPage"
             x:DataType="viewmodels:ScoreDetailViewModel"
             Title="Détail du Match">
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Image en bannière -->
            <Image Source="{Binding Match.ImageUrl}"
                   Aspect="AspectFill"
                   HeightRequest="220" />

            <VerticalStackLayout Spacing="16" Padding="20,20">

                <!-- Nom du match -->
                <Label Text="{Binding Match.NomMatch}"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <!-- Score final -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource Gray100}"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.07" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="SCORE FINAL"
                               FontSize="11"
                               TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center"
                               CharacterSpacing="1.5" />
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                            <Label Grid.Column="0"
                                   Text="{Binding Match.EquipeDomicile}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding Match.ScoreDisplay}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding Match.EquipeExterieur}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Score par set -->
                <Label Text="SCORE PAR SET"
                       FontSize="11"
                       TextColor="{StaticResource Gray400}"
                       CharacterSpacing="1.5"
                       Margin="0,4,0,0" />

                <VerticalStackLayout Spacing="8"
                                     BindableLayout.ItemsSource="{Binding Match.TennisSetsFormatted}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border StrokeShape="RoundRectangle 12"
                                    Stroke="{StaticResource Gray100}"
                                    BackgroundColor="White"
                                    Padding="16,12">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Radius="4" Opacity="0.05" />
                                </Border.Shadow>
                                <Label Text="{Binding .}"
                                       FontSize="15"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
