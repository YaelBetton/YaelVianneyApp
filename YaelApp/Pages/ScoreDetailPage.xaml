<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YaelApp.ViewModels"
             x:Class="YaelApp.Pages.ScoreDetailPage"
             x:DataType="viewmodels:ScoreDetailViewModel"
             Title="Détail du Match">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <Image Source="{Binding Match.ImageUrl}" 
                   HeightRequest="250" 
                   Aspect="AspectFit" 
                   HorizontalOptions="Center" />
            <Label Text="{Binding Match.NomMatch}" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center"/>
            <Frame BackgroundColor="#F0F0F0" Padding="15" CornerRadius="10" HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Score final :" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Grid ColumnDefinitions="*, Auto, *" ColumnSpacing="15">
                        <Label Grid.Column="0" Text="{Binding Match.EquipeDomicile}" FontSize="16" HorizontalOptions="End" />
                        <Label Grid.Column="1" Text="{Binding Match.ScoreDisplay}" FontSize="20" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="{Binding Match.EquipeExterieur}" FontSize="16" HorizontalOptions="Start" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            <Label Text="Score par set"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,10,0,0"/>
            <VerticalStackLayout Spacing="6"
                                 BindableLayout.ItemsSource="{Binding Match.TennisSetsFormatted}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Padding="12,8" StrokeShape="RoundRectangle 8" BackgroundColor="#F5F5F5" Stroke="Transparent">
                            <Label Text="{Binding .}" FontSize="15" TextColor="DarkGreen" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
