<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:YaelApp.ViewModels"
             xmlns:models="clr-namespace:YaelApp.Models"
             x:Class="YaelApp.Pages.VolleyScorePage"
             x:DataType="vm:VolleyScoreViewModel"
             Title="Score Live Volley">
    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- ======================================================= -->
            <!-- FONCTIONNALITÉ 1 : COMPTEUR DE SCORE EN DIRECT           -->
            <!-- ======================================================= -->
            <Label Text="Compteur de score en direct"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Avant le match : saisie des noms d'équipes -->
            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding IsSetupVisible}">
                <Label Text="Noms des équipes"
                       FontSize="16"
                       HorizontalOptions="Center"
                       TextColor="Gray" />
                <Border Stroke="LightGray" StrokeShape="RoundRectangle 10" Padding="4">
                    <Entry Placeholder="Équipe A"
                           Text="{Binding TeamAName}"
                           FontSize="16"
                           HorizontalOptions="FillAndExpand" />
                </Border>
                <Border Stroke="LightGray" StrokeShape="RoundRectangle 10" Padding="4">
                    <Entry Placeholder="Équipe B"
                           Text="{Binding TeamBName}"
                           FontSize="16"
                           HorizontalOptions="FillAndExpand" />
                </Border>
                <Button Text="Démarrer le match"
                        Command="{Binding StartMatchCommand}"
                        HorizontalOptions="Center"
                        Padding="24,12" />
            </VerticalStackLayout>

            <!-- Pendant / après le match -->
            <VerticalStackLayout Spacing="16"
                                 IsVisible="{Binding IsLiveVisible}">

                <!-- Set en cours -->
                <Label Text="{Binding CurrentSet, StringFormat='Set {0} / 5'}"
                       FontSize="18"
                       HorizontalOptions="Center"
                       TextColor="Gray" />

                <!-- Score du set en cours -->
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">

                    <!-- Équipe A -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="8">
                        <Label Text="{Binding TeamAName}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ScoreA}"
                               FontSize="56"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#1565C0" />
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               IsVisible="{Binding AreButtonsVisible}">
                            <Button Text="-"
                                    Command="{Binding RemovePointACommand}"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    BackgroundColor="#EF9A9A"
                                    TextColor="Black"
                                    CornerRadius="25"
                                    Padding="0" />
                            <Button Text="+"
                                    Command="{Binding AddPointACommand}"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    BackgroundColor="#A5D6A7"
                                    TextColor="Black"
                                    CornerRadius="25"
                                    Padding="0" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Séparateur -->
                    <Label Grid.Column="1"
                           Text="—"
                           FontSize="40"
                           VerticalOptions="Start"
                           Margin="0,28,0,0" />

                    <!-- Équipe B -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="8">
                        <Label Text="{Binding TeamBName}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ScoreB}"
                               FontSize="56"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#B71C1C" />
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               IsVisible="{Binding AreButtonsVisible}">
                            <Button Text="-"
                                    Command="{Binding RemovePointBCommand}"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    BackgroundColor="#EF9A9A"
                                    TextColor="Black"
                                    CornerRadius="25"
                                    Padding="0" />
                            <Button Text="+"
                                    Command="{Binding AddPointBCommand}"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    BackgroundColor="#A5D6A7"
                                    TextColor="Black"
                                    CornerRadius="25"
                                    Padding="0" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Score des sets -->
                <Frame CornerRadius="12" Padding="16" BackgroundColor="#F5F5F5" HasShadow="False">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sets remportés"
                               FontSize="13"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center">
                            <Label.Text>
                                <MultiBinding StringFormat="{}{0}  —  {1}">
                                    <Binding Path="SetsA" />
                                    <Binding Path="SetsB" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Label Text="{Binding SetHistory}"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Message de fin de match -->
                <Frame CornerRadius="12"
                       Padding="16"
                       BackgroundColor="#E8F5E9"
                       HasShadow="True"
                       IsVisible="{Binding IsFinishedVisible}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Match terminé !"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#2E7D32" />
                        <Label FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="#2E7D32">
                            <Label.Text>
                                <MultiBinding StringFormat="Vainqueur : {0}  ({1} - {2})">
                                    <Binding Path="Winner" />
                                    <Binding Path="SetsA" />
                                    <Binding Path="SetsB" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Button Text="Enregistrer dans Score"
                                Command="{Binding SaveMatchCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="20,10"
                                HorizontalOptions="Center"
                                IsVisible="{Binding IsSaveButtonVisible}" />
                        <Label Text="Match enregistré !"
                               FontSize="14"
                               TextColor="#4CAF50"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               IsVisible="{Binding IsSavedLabelVisible}" />
                        <Button Text="Nouveau match"
                                Command="{Binding ResetMatchCommand}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="10"
                                Padding="20,10"
                                HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Bouton annuler (pendant le match uniquement) -->
                <Button Text="Annuler le match"
                        Command="{Binding ResetMatchCommand}"
                        BackgroundColor="#FFCDD2"
                        TextColor="#B71C1C"
                        CornerRadius="10"
                        HorizontalOptions="Center"
                        IsVisible="{Binding AreButtonsVisible}" />
            </VerticalStackLayout>

            <!-- ======================================================= -->
            <!-- FONCTIONNALITÉ 2 : HISTORIQUE DES MATCHS JOUÉS           -->
            <!-- ======================================================= -->
            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="Historique des matchs joués"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Aucun match enregistré pour l'instant."
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   IsVisible="{Binding NoHistory}" />

            <CollectionView ItemsSource="{Binding MatchHistory}"
                            SelectionMode="None"
                            IsVisible="{Binding HasHistory}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MatchModel">
                        <Frame Margin="0,6" Padding="14" CornerRadius="12" HasShadow="True">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding NomMatch}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label FontSize="14" TextColor="DarkGreen">
                                    <Label.Text>
                                        <MultiBinding StringFormat="Sets : {0} — {1}">
                                            <Binding Path="ScoreHome" />
                                            <Binding Path="ScoreAway" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding ResultatRaw, StringFormat='Détail : {0}'}"
                                       FontSize="12"
                                       TextColor="Gray" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
