<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YaelApp.ViewModels"
             xmlns:models="clr-namespace:YaelApp.Models"
             x:Class="YaelApp.Pages.ScorePage"
             x:DataType="viewmodels:ScoreViewModel"
             Title="Score">
    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="16">
            <!-- Bandeau descriptif -->
            <VerticalStackLayout Spacing="15" HorizontalOptions="Center" WidthRequest="300">
                <Image Source="scores_image.jpg"
                       SemanticProperties.Description="Image de scores sportifs"
                       HeightRequest="200"
                       WidthRequest="200"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />
                <Label Text="Score"
                       SemanticProperties.HeadingLevel="Level1"
                       FontSize="32"
                       HorizontalOptions="Center" />
                <Label Text="Retrouve ici les scores et résultats des matchs."
                       FontSize="18"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Label Text="Résultats Tennis" FontSize="24" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding TennisMatchesVM}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:TennisMatchViewModel">
                        <Frame Margin="0,6" Padding="12" CornerRadius="12" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.GoToDetailCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                      CommandParameter="{Binding Match}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Image Grid.Column="0"
                                       Source="{Binding ImageUrl}"
                                       WidthRequest="72"
                                       HeightRequest="72"
                                       Aspect="AspectFill"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding NomMatch}" FontSize="20" FontAttributes="Bold" />
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="{Binding SetsFormatted[0]}" FontSize="15" TextColor="DarkGreen"/>
                                        <Label Text="{Binding SetsFormatted[1]}" FontSize="15" TextColor="DarkGreen"/>
                                        <Label Text="{Binding SetsFormatted[2]}" FontSize="15" TextColor="DarkGreen"/>
                                        <Label Text="{Binding SetsFormatted[3]}" FontSize="15" TextColor="DarkGreen"/>
                                        <Label Text="{Binding SetsFormatted[4]}" FontSize="15" TextColor="DarkGreen"/>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="↗"
                                        FontSize="18"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        VerticalOptions="Center"
                                        Command="{Binding BindingContext.ShareMatchCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding Match}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Section volley -->
            <Label Text="Résultats Volley" FontSize="24" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding VolleyMatches}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MatchModel">
                        <Frame Margin="0,6" Padding="12" CornerRadius="12" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.GoToDetailCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Image Grid.Column="0"
                                       Source="{Binding ImageUrl}"
                                       WidthRequest="72"
                                       HeightRequest="72"
                                       Aspect="AspectFill"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding NomMatch}" FontSize="20" FontAttributes="Bold" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="↗"
                                        FontSize="18"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        VerticalOptions="Center"
                                        Command="{Binding BindingContext.ShareMatchCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
