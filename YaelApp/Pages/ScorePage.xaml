<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.ScorePage"
             Title="Score">
    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,20"
            VerticalOptions="Center">

            <Image
                Source="scores_image.jpg"
                SemanticProperties.Description="Image de scores sportifs"
                HeightRequest="200"
                WidthRequest="200"
                Aspect="AspectFit"
                HorizontalOptions="Center" />

            <Label
                Text="Score"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />

            <Label
                Text="Retrouve ici les scores et resultats des matchs."
                FontSize="18"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

