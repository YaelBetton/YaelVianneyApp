<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.VolleyPage"
             Title="Volley">
    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,20"
            VerticalOptions="Center">
            <Image
                Source="volley_image.jpg"
                SemanticProperties.Description="Image de volley-ball"
                HeightRequest="200"
                WidthRequest="200"
                Aspect="AspectFit"
                HorizontalOptions="Center" />
            <Label
                Text="Volley"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />
            <Label
                Text="Informations sur le volley-ball"
                FontSize="18"
                HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
