<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YaelApp.Pages.TennisPage"
             Title="Tennis">
    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,20"
            VerticalOptions="Center">
            <Image
                Source="tennis_image.jpg"
                SemanticProperties.Description="Image de tennis"
                HeightRequest="200"
                WidthRequest="200"
                Aspect="AspectFit"
                HorizontalOptions="Center" />
            <Label
                Text="Tennis"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />

            <Entry x:Name="Player1Entry" Placeholder="Nom du Joueur 1" />
            <Entry x:Name="Player2Entry" Placeholder="Nom du Joueur 2" />
            <DatePicker x:Name="MatchDatePicker" Format="dd/MM/yyyy" />
            <Label Text="Sets" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" />
            <StackLayout x:Name="SetsStack" Spacing="10" />
            <Button x:Name="AddSetButton" Text="Ajouter un set" Clicked="OnAddSetClicked" />
            <Button Text="Enregistrer le match" Clicked="OnSaveMatchClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
